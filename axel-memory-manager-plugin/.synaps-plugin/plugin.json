{
  "name": "axel-memory-manager",
  "version": "0.1.0",
  "description": "Axel — portable agent intelligence (search, memory, self-organizing knowledge) backed by VolciRAG, Memkoshi, and Consolidation. One .r8 file is the agent's entire brain.",
  "author": {
    "name": "J.R. Morton",
    "url": "https://github.com/maha-media"
  },
  "repository": "https://github.com/maha-media/synaps-skills",
  "license": "MIT",
  "category": "productivity",
  "extension": {
    "name": "memory-manager",
    "runtime": "process",
    "command": "extensions/memory-manager/target/release/memory-manager",
    "args": [],
    "setup": "scripts/setup.sh",
    "permissions": [
      "tools.intercept",
      "privacy.llm_content",
      "session.lifecycle",
      "config.subscribe"
    ],
    "hooks": [
      { "hook": "before_message" },
      { "hook": "on_message_complete" },
      { "hook": "after_tool_call" },
      { "hook": "on_session_start" },
      { "hook": "on_session_end" }
    ]
  },
  "settings": {
    "categories": [
      {
        "id": "axel",
        "label": "Axel Memory",
        "fields": [
          {
            "key": "min_consolidate_len",
            "label": "Min consolidation length",
            "editor": "text",
            "numeric": true,
            "default": "40",
            "help": "Messages shorter than this byte length are skipped during consolidation."
          },
          {
            "key": "consolidate_interval_secs",
            "label": "Background consolidation interval (seconds)",
            "editor": "cycler",
            "options": ["0", "60", "300", "900", "3600"],
            "default": "0",
            "help": "0 disables the background timer (Phase 2)."
          },
          {
            "key": "run_consolidate_now",
            "label": "Run consolidation now",
            "editor": "custom",
            "help": "Triggers an immediate consolidation pass."
          }
        ]
      }
    ]
  }
}
