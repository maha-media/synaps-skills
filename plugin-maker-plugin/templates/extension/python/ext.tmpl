#!/usr/bin/env python3
"""
${NAME} — SynapsCLI extension.

Implements the v1 extension protocol over JSON-RPC 2.0 on stdio.
Frames use LSP-style Content-Length framing over stdio. SynapsCLI calls:

  initialize(config)                  → returns {protocol_version, capabilities}
  tools.list()                        → list of tools we register (if any)
  tools.invoke(name, input)           → invoke one
  hook.handle({kind, ...})             → fires for every subscribed hook
  command.invoke(name, args, …)       → for `interactive: true` slash commands
  settings.editor.open(field)         → open a `editor: custom` overlay
  settings.editor.render()            → re-render after a key
  settings.editor.key(key)            → forward a keypress
  settings.editor.commit()            → persist & close
  shutdown()                          → graceful exit

Reference: src/extensions/manifest.rs and the host-side runtime in
src/extensions/runtime/process.rs.
"""

from __future__ import annotations

import json
import os
import sys
import traceback
from typing import Any


# ── JSON-RPC plumbing (LSP-style Content-Length framing) ──────────────

def send(obj: dict[str, Any]) -> None:
    body = json.dumps(obj, separators=(",", ":")).encode("utf-8")
    sys.stdout.buffer.write(b"Content-Length: " + str(len(body)).encode("ascii") + b"\r\n\r\n")
    sys.stdout.buffer.write(body)
    sys.stdout.buffer.flush()


def read_frame() -> dict[str, Any] | None:
    content_length: int | None = None
    while True:
        line = sys.stdin.buffer.readline()
        if line == b"":
            return None
        if line in (b"\r\n", b"\n"):
            break
        name, _, value = line.decode("ascii", "replace").partition(":")
        if name.lower() == "content-length":
            content_length = int(value.strip())
    if content_length is None:
        raise RuntimeError("missing Content-Length header")
    return json.loads(sys.stdin.buffer.read(content_length).decode("utf-8"))


def reply(req_id: Any, result: Any) -> None:
    send({"jsonrpc": "2.0", "id": req_id, "result": result})


def reply_error(req_id: Any, code: int, message: str, data: Any = None) -> None:
    err = {"code": code, "message": message}
    if data is not None:
        err["data"] = data
    send({"jsonrpc": "2.0", "id": req_id, "error": err})


def notify(method: str, params: Any) -> None:
    send({"jsonrpc": "2.0", "method": method, "params": params})


# ── Handlers ───────────────────────────────────────────────────────────────

CONFIG: dict[str, Any] = {}


def handle_initialize(params: dict) -> dict:
    """Receive the host-resolved config and declare what we support."""
    global CONFIG
    CONFIG = params.get("config", {}) or {}
    return {
        "protocol_version": 1,
        "extension": "${NAME}",
        "capabilities": [],   # add "tools" / "providers" if you register them
    }


def handle_hook(params: dict) -> dict:
    """Generic hook dispatcher.

    `params["kind"]` tells you which hook fired. Permissions and tool filters
    are pre-validated by the host — you only see hooks you subscribed to.

    Return one of:
      {"action": "continue"}                         (always allowed)
      {"action": "block",   "reason": "..."}         (before_tool_call)
      {"action": "modify",  "input": {...}}          (before_tool_call)
      {"action": "confirm", "prompt": "..."}         (before_tool_call)
      {"action": "inject",  "content": "..."}        (before_message)
    """
    kind = params.get("kind", "")
    # event = params.get("event", {})

    # Example: log session lifecycle to stderr.
    if kind in ("on_session_start", "on_session_end"):
        sys.stderr.write(f"[${NAME}] {kind}\n")

    return {"action": "continue"}


def handle_command_invoke(params: dict) -> dict:
    """Handle interactive slash commands routed here.

    `params` shape: {"name": str, "args": list[str], "tty_cols": int, ...}.
    Return: {"output": str}  (rendered as a system message).
    """
    name = params.get("name", "")
    args = params.get("args", [])
    return {"output": f"${NAME}: {name} {' '.join(args)} (stub)"}


def handle_shutdown(_params: dict) -> dict:
    return {"ok": True}


# ── Dispatcher ─────────────────────────────────────────────────────────────

HANDLERS = {
    "initialize":     handle_initialize,
    "hook.handle":    handle_hook,
    "command.invoke": handle_command_invoke,
    "shutdown":       handle_shutdown,
}


def main() -> None:
    while True:
        try:
            msg = read_frame()
            if msg is None:
                return
        except Exception as exc:  # noqa: BLE001
            sys.stderr.write(f"[${NAME}] bad frame: {exc}\n")
            continue

        method = msg.get("method", "")
        req_id = msg.get("id")
        params = msg.get("params") or {}

        handler = HANDLERS.get(method)
        if handler is None:
            if req_id is not None:
                reply_error(req_id, -32601, f"method not found: {method}")
            continue

        try:
            result = handler(params)
            if req_id is not None:
                reply(req_id, result)
        except Exception as exc:  # noqa: BLE001
            tb = traceback.format_exc()
            sys.stderr.write(f"[${NAME}] handler error: {tb}\n")
            if req_id is not None:
                reply_error(req_id, -32000, str(exc), {"traceback": tb})

        if method == "shutdown":
            return


if __name__ == "__main__":
    main()
