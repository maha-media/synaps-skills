#!/usr/bin/env -S deno run
// ${NAME}-sidecar — SynapsCLI sidecar in Deno.

const readline = require("readline");
const NAME = "${NAME}";

function emit(obj) {
  process.stdout.write(JSON.stringify(obj) + "\n");
}

function hello() {
  emit({ type: "hello", protocol_version: 2, extension: NAME, capabilities: [] });
}

function status(state, label) {
  emit({ type: "status", state, label, capabilities: [] });
}

function trigger(frame) {
  const name = frame.name || "trigger";
  status("busy", `${NAME} working`);
  emit({ type: "insert_text", text: `${NAME}: trigger '${name}' received`, mode: "final" });
  status("idle", `${NAME} ready`);
}

hello();
status("idle", `${NAME} ready`);

const rl = readline.createInterface({ input: process.stdin, crlfDelay: Infinity });
rl.on("line", (line) => {
  if (!line.trim()) return;
  let frame;
  try {
    frame = JSON.parse(line);
  } catch (err) {
    emit({ type: "error", message: `bad JSON: ${err.message}` });
    return;
  }
  switch (frame.type) {
    case "init":
      status("idle", `${NAME} ready`);
      break;
    case "trigger":
      trigger(frame);
      break;
    case "shutdown":
      rl.close();
      process.exit(0);
      break;
    default:
      emit({ type: "error", message: `unknown frame type: ${frame.type}` });
  }
});
