{
  "name": "plugin-maker",
  "version": "0.1.0",
  "description": "Scaffold, validate, lint, and inspect Synaps CLI plugins. Knows the full surface — manifests, skills, extensions, sidecars, settings, keybinds, commands, hooks, and the lightbox/help integration. Use when starting a new plugin, adding any feature to an existing plugin, or auditing the installed plugin set.",
  "author": {
    "name": "Maha Media",
    "url": "https://github.com/maha-media"
  },
  "repository": "maha-media/synaps-skills",
  "license": "MIT",
  "category": "developer-tools",
  "compatibility": {
    "synaps": ">=0.1.0",
    "extension_protocol": "1"
  },

  "commands": [
    {
      "name": "plugin-maker",
      "description": "Plugin Maker — scaffold, validate, lint, and inspect plugins.",
      "interactive": true,
      "subcommands": [
        "new", "validate", "lint", "doctor", "info", "list", "catalog", "help"
      ]
    }
  ],

  "keybinds": [
    {
      "key": "C-S-p",
      "action": "slash_command",
      "command": "plugin-maker doctor .",
      "description": "Run plugin-maker doctor on the current directory"
    }
  ],

  "help_entries": [
    {
      "id": "plugin-maker-overview",
      "command": "/plugin-maker",
      "title": "Plugin Maker",
      "summary": "Scaffold, validate, lint, and inspect Synaps CLI plugins.",
      "category": "Plugin",
      "topic": "Branch",
      "common": true,
      "keywords": ["plugin", "scaffold", "validate", "lint", "skill", "extension", "sidecar"],
      "usage": "/plugin-maker <subcommand> [args]",
      "examples": [
        {"command": "/plugin-maker new plugin my-tool",  "description": "Scaffold a new plugin in ./my-tool-plugin/"},
        {"command": "/plugin-maker doctor .",           "description": "Validate + lint every plugin under the current directory"}
      ],
      "related": ["/plugin-maker new", "/plugin-maker validate", "/plugin-maker doctor"]
    },
    {
      "id": "plugin-maker-new",
      "command": "/plugin-maker new",
      "title": "Plugin Maker: new",
      "summary": "Scaffold a plugin, skill, extension, sidecar, command, keybind, or settings entry.",
      "category": "Plugin",
      "topic": "Command",
      "keywords": ["new", "scaffold", "create", "generate"],
      "usage": "/plugin-maker new <plugin|skill|extension|sidecar|command|keybind|settings|field> ...",
      "examples": [
        {"command": "/plugin-maker new plugin my-tool --umbrella",          "description": "Umbrella-layout plugin with docs/ progressive disclosure"},
        {"command": "/plugin-maker new extension --hooks before_tool_call", "description": "Add an extension stub with a hook subscription"},
        {"command": "/plugin-maker new sidecar --lifecycle-cmd capture",    "description": "Add a sidecar with the Phase-8 lifecycle UX"}
      ],
      "related": ["/plugin-maker validate", "/plugin-maker doctor"]
    },
    {
      "id": "plugin-maker-validate",
      "command": "/plugin-maker validate",
      "title": "Plugin Maker: validate",
      "summary": "Structural validation. Errors → exit 1.",
      "category": "Plugin",
      "topic": "Command",
      "keywords": ["validate", "check", "structure", "schema"],
      "usage": "/plugin-maker validate [PATH]",
      "examples": [
        {"command": "/plugin-maker validate",   "description": "Validate the plugin in cwd"},
        {"command": "/plugin-maker validate .", "description": "Validate every plugin found under cwd"}
      ],
      "related": ["/plugin-maker lint", "/plugin-maker doctor"]
    },
    {
      "id": "plugin-maker-lint",
      "command": "/plugin-maker lint",
      "title": "Plugin Maker: lint",
      "summary": "Quality checks (warnings; --strict promotes to errors).",
      "category": "Plugin",
      "topic": "Command",
      "keywords": ["lint", "quality", "style"],
      "usage": "/plugin-maker lint [--strict] [PATH]",
      "examples": [
        {"command": "/plugin-maker lint",          "description": "Lint cwd plugin"},
        {"command": "/plugin-maker lint --strict", "description": "Fail on any warning"}
      ],
      "related": ["/plugin-maker validate", "/plugin-maker doctor"]
    },
    {
      "id": "plugin-maker-doctor",
      "command": "/plugin-maker doctor",
      "title": "Plugin Maker: doctor",
      "summary": "Full health check — validate + lint + install-readiness.",
      "category": "Plugin",
      "topic": "Command",
      "keywords": ["doctor", "health", "audit", "diagnose"],
      "usage": "/plugin-maker doctor [PATH]",
      "examples": [
        {"command": "/plugin-maker doctor .", "description": "Audit every plugin under cwd"}
      ],
      "related": ["/plugin-maker validate", "/plugin-maker lint", "/plugin-maker info"]
    },
    {
      "id": "plugin-maker-info",
      "command": "/plugin-maker info",
      "title": "Plugin Maker: info",
      "summary": "Rich summary of a plugin — skills, extension, hooks, sidecar, settings, keybinds.",
      "category": "Plugin",
      "topic": "Command",
      "keywords": ["info", "inspect", "describe"],
      "usage": "/plugin-maker info [PATH]",
      "related": ["/plugin-maker list", "/plugin-maker doctor"]
    },
    {
      "id": "plugin-maker-catalog",
      "command": "/plugin-maker catalog",
      "title": "Plugin Maker: catalog",
      "summary": "Print the canonical catalog: hooks, permissions, hook→permission map, sidecar frames, editor kinds, action types.",
      "category": "Plugin",
      "topic": "Command",
      "keywords": ["catalog", "reference", "hooks", "permissions"],
      "usage": "/plugin-maker catalog <hooks|permissions|hook-permissions|sidecar-frames|editor-kinds|action-types>",
      "examples": [
        {"command": "/plugin-maker catalog hooks",       "description": "List the 7 hook kinds with required permissions"},
        {"command": "/plugin-maker catalog permissions", "description": "List the 12 extension permissions"}
      ]
    }
  ],

  "settings": {
    "categories": [
      {
        "id": "plugin-maker",
        "label": "Plugin Maker",
        "fields": [
          {
            "key": "default_layout",
            "label": "Default scaffold layout",
            "editor": "cycler",
            "options": ["single", "umbrella", "memory"],
            "default": "single",
            "help": "Layout used by `plugin-maker new plugin` when no flag is passed."
          },
          {
            "key": "default_category",
            "label": "Default plugin.json category",
            "editor": "text",
            "default": "productivity",
            "help": "Seed for the `category` field in newly scaffolded plugin.json files."
          },
          {
            "key": "default_license",
            "label": "Default license",
            "editor": "cycler",
            "options": ["MIT", "Apache-2.0", "GPL-3.0", "BSD-3-Clause", "UNLICENSED"],
            "default": "MIT",
            "help": "Seed for the `license` field in newly scaffolded plugin.json files."
          },
          {
            "key": "strict_lint",
            "label": "Strict lint by default",
            "editor": "cycler",
            "options": ["off", "on"],
            "default": "off",
            "help": "When `on`, `plugin-maker lint` runs as if `--strict` was passed."
          },
          {
            "key": "browse_plugins",
            "label": "Browse installed plugins",
            "editor": "custom",
            "help": "Open the Plugin Browser — a live overlay of every installed plugin with validate/lint status and quick actions."
          }
        ]
      }
    ]
  },

  "extension": {
    "protocol_version": 1,
    "runtime": "process",
    "command": "python3",
    "args": ["extensions/plugin_maker_ext.py"],
    "permissions": [
      "tools.intercept",
      "session.lifecycle",
      "config.write",
      "config.subscribe"
    ],
    "hooks": [
      {"hook": "on_session_start"},
      {
        "hook": "before_tool_call",
        "tool": "bash",
        "match": {"input_contains": "plugin.json"}
      },
      {
        "hook": "after_tool_call",
        "tool": "bash",
        "match": {"input_contains": "plugin.json"}
      }
    ],
    "config": [
      {
        "key": "default_layout",
        "type": "string",
        "description": "Default scaffold layout (single|umbrella|memory).",
        "default": "single"
      },
      {
        "key": "default_category",
        "type": "string",
        "description": "Default plugin.json category seed.",
        "default": "productivity"
      },
      {
        "key": "default_license",
        "type": "string",
        "description": "Default license string.",
        "default": "MIT"
      },
      {
        "key": "strict_lint",
        "type": "string",
        "description": "When 'on', lint runs in --strict mode.",
        "default": "off"
      },
      {
        "key": "session_health_summary",
        "type": "bool",
        "description": "Print a one-line health summary at session start.",
        "default": true
      },
      {
        "key": "auto_validate_on_edit",
        "type": "bool",
        "description": "Auto-run `plugin-maker validate` after a bash edit touches a plugin.json.",
        "default": true
      }
    ]
  }
}
