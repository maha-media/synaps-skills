{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Quality Score",
  "description": "Arbiter's quality scoring output schema. Fixed dimensions resist prompt drift.",
  "type": "object",
  "required": ["overall", "dimensions", "verdict", "stage"],
  "properties": {
    "overall": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Weighted overall score: spec×0.35 + quality×0.2 + tests×0.2 + edges×0.15 + security×0.1"
    },
    "dimensions": {
      "type": "object",
      "required": ["spec_compliance", "code_quality", "test_coverage", "edge_cases", "security"],
      "properties": {
        "spec_compliance": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Does the implementation match the spec?"
        },
        "code_quality": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Is the code clean, readable, maintainable?"
        },
        "test_coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Are tests adequate?"
        },
        "edge_cases": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Are edge cases handled?"
        },
        "security": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Are security considerations addressed?"
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["PROCEED", "REVIEW", "REWORK"],
      "description": "PROCEED (≥0.8), REVIEW (0.7-0.79), REWORK (<0.7)"
    },
    "stage": {
      "type": "string",
      "enum": ["right_thing", "right_way"],
      "description": "Which review stage produced this score"
    },
    "notes": {
      "type": "string",
      "description": "Optional notes about the scoring"
    }
  }
}
